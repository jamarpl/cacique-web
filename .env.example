# Cacique frontend (cacique-web) environment variables — local development
# defaults.
#
# Copy this file to `.env.local` (gitignored, Next.js convention) and adjust
# values as needed. Only variables prefixed `NEXT_PUBLIC_` are exposed to the
# browser bundle — never put secrets in a NEXT_PUBLIC_* var.
#
# This app has no Docker/docker-compose wiring yet (UIRB-INFRA-1/2/3
# deliberately defer containerization); run it with `npm run dev` against a
# backend also running locally.

# --- Backend API base URL ---
#
# Cacique.Api's actual local dev port, confirmed from
# Cacique/Cacique.Api/Properties/launchSettings.json (the "http" launch
# profile's applicationUrl) — NOT guessed. Use this value when running the
# backend directly via `dotnet run` (or F5/`dotnet watch`) from
# Cacique/Cacique.Api.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5063

# Alternative: if the backend is instead run via `docker compose up` (see
# repo-root docker-compose.yml / .env.example), it's published on
# BACKEND_HOST_PORT (default 8080) instead:
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# --- API key (minimal "stop randoms" gate, ApiKeyGateMiddleware) ---
#
# Empty in local dev — backend's Auth:ApiKey is also unset locally, so the
# gate no-ops on both sides. In a real deployment, set this to match the
# backend's Auth__ApiKey env var exactly.
NEXT_PUBLIC_API_KEY=

# --- Dev server origin (informational, not consumed by this app) ---
#
# `next dev` serves this app on http://localhost:3000 by default (Next.js
# default port, not currently overridden here). This is the origin that
# Cacique.Api's CORS policy (UIRB-BACK-1) must allow for browser-side fetch
# calls from cacique-web to succeed in local dev.
